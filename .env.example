# NEVER commit your real .env file.

ANTHROPIC_API_KEY=your-api-key-here
# Optional overrides
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=4096
PORT=3000
CORS_ORIGIN=http://localhost:4200
