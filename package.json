{
  "name": "angular-ai-chat",
  "version": "1.0.0",
  "description": "Angular 21 streaming chat application with Claude API integration",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "backend": "node backend/proxy.js",
    "backend:dev": "nodemon backend/proxy.js",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:backend\" \"npm:start\""
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@anthropic-ai/sdk": "^0.70.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "marked": "^14.1.3",
    "rxjs": "^7.8.1",
    "tslib": "^2.7.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.7",
    "typescript": "~5.9.0"
  }
}
